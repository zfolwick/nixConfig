#!/usr/bin/env bash

# This is an initial script to automate the acquisition of software.

#function to check if program is installed
function is_installed () {
    type "$1" &> /dev/null;
}

# Figure out the package manager.
if is_installed apt-get;
then
    pkg_mgr=apt-get
    add-apt-repository universe

elif is_installed rpm;
then
    pkg_mgr=yum
    rpm -Uvh http://download.fedora.redhat.com/pub/epel/5/i386/epel-release-5-4.noarch.rpm

elif is_installed apt-cyg;
then
    pkg_mgr=apt-cyg

fi


${pkg_mgr} update
${pkg_mgr} upgrade

# now the packages repo is up to date, begin installing programs:

${pkg_mgr} install -y htop \
                      tree \
                      vim \
                      emacs \
                      curl \
                      tmux \
                      silversearcher-ag \
                      docker \
                      gnome-session-flashback \
                      metacity \
                      eclipse \
                      gcc \
                      g++

# now that git is installed, begin bringing in config files.

# untar all the configuration files to the home directory
tar -xvf config.files.tar -C ~/

# Unpack and copy config files over to ~/ directory

## Vim
# Get Pathogen:
mkdir -p ~/.vim/autoload ~/.vim/bundle && \
curl -LSso ~/.vim/autoload/pathogen.vim https://tpo.pe/pathogen.vim

# Configure the keyboard: 
# 1. swap the caps lock with control keys - Source: www.noah.org/wike/CapsLock_Remap: this is accomplished in the bashrc file
# 2. turn the right shift key into a forward delete key


source ~/.bashrc
